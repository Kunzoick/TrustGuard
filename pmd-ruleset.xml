<?xml version="1.0" encoding="UTF-8"?>
<ruleset name="TrustGuard PMD Ruleset"
         xmlns="http://pmd.sourceforge.net/ruleset/2.0.0"
         xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
         xsi:schemaLocation="http://pmd.sourceforge.net/ruleset/2.0.0
         https://pmd.sourceforge.io/ruleset_2_0_0.xsd">

  <description>
    TrustGuard PMD ruleset compatible with PMD 7.3.0.
    Rule 19.5 — UnusedImports enforced via Checkstyle
    UnusedImports module instead (already active).
    PMD handles empty blocks and duplicate literals.
  </description>

  <!-- EmptyCatchBlock — valid in PMD 7 -->
  <rule ref="category/java/errorprone.xml/EmptyCatchBlock">
    <properties>
      <property name="allowCommentedBlocks" value="true"/>
    </properties>
  </rule>

  <!-- AvoidDuplicateLiterals — valid in PMD 7,
       no custom properties to avoid version conflicts -->
  <rule ref="category/java/errorprone.xml/AvoidDuplicateLiterals"/>

  <!-- AvoidCatchingThrowable — valid in PMD 7 -->
  <rule ref="category/java/errorprone.xml/AvoidCatchingThrowable"/>

  <!-- UnusedPrivateMethod — valid in PMD 7 -->
  <rule ref="category/java/bestpractices.xml/UnusedPrivateMethod"/>

  <!-- AvoidDeeplyNestedIfStmts — valid in PMD 7 -->
  <rule ref="category/java/design.xml/AvoidDeeplyNestedIfStmts"/>

</ruleset>